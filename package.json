{
  "name": "sub-display-hud",
  "version": "0.1.0",
  "private": true,
  "description": "A privacy-aware HUD for a secondary display.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "package": "electron-builder --mac dir",
    "dist": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "local.sub-display-hud",
    "productName": "Sub Display HUD",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dir",
        "dmg"
      ],
      "identity": null
    },
    "dmg": {
      "sign": false
    },
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1"
  }
}
